# Used to encrypt the secrets store (API keys + Gmail password). Set to any
# long random string. REQUIRED in production — required locally too if you
# want your saved settings to persist across restarts.
APP_SECRET=change-me-to-a-long-random-string

# --- Deployed (Vercel) only ---
# Password that gates the whole app once it's on the internet. Leave unset
# for local dev to skip the login screen. Set this in Vercel's env vars.
APP_PASSWORD=

# Auto-populated by Vercel when you attach a "Redis" (Upstash) integration to
# your project — you normally do NOT set these by hand. Either naming works;
# the app checks both. Without them, the app falls back to local JSON files
# under /data (fine for local dev, NOT durable on a serverless host).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# (legacy naming some integrations use instead — also supported)
KV_REST_API_URL=
KV_REST_API_TOKEN=

# --- Optional AI provider key fallbacks (only used if not set in Settings UI) ---
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=
GROQ_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434

# --- Optional Gmail fallback (Gmail address + App Password, not your normal password) ---
GMAIL_USER=
GMAIL_APP_PASSWORD=
