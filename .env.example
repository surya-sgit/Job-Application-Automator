# Used to (1) sign user session tokens and (2) encrypt each user's stored
# API keys/Gmail password. Set to any long random string. REQUIRED whenever
# DATABASE_URL is set (accounts/sessions depend on it); recommended locally
# too so saved settings persist across restarts.
APP_SECRET=change-me-to-a-long-random-string

# Postgres connection string (Neon, or any Postgres). When set, the app
# creates `users` and `user_data` tables on first use and requires real
# sign-up/login (no more shared password) — each account gets its own
# profile/projects/settings. Without this, the app falls back to local JSON
# files under /data: single-user, no accounts, no login screen (fine for
# quick local dev, NOT durable on a serverless host and NOT multi-user).
DATABASE_URL=

# --- Optional AI provider key fallbacks (only used if not set in Settings UI) ---
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=
GROQ_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434

# --- Optional Gmail fallback (Gmail address + App Password, not your normal password) ---
GMAIL_USER=
GMAIL_APP_PASSWORD=
